# Application Environment (development, testing, production)
APP_ENV=development
APP_NAME="MindGuard AI"
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=10000

# Database Configuration (supports MySQL, SQLite, PostgreSQL)
DATABASE_URL=mysql+aiomysql://dbadmin:password@localhost:3306/mindguard

# Redis Configuration (future caching)
REDIS_URL=redis://localhost:6379/0

# Security Settings (Run 'openssl rand -hex 32' to generate keys)
JWT_SECRET_KEY=yoursecretkeyhere
JWT_REFRESH_SECRET_KEY=yourrefreshsecretkeyhere
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration (JSON array of strings)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME="MindGuard AI Team"
